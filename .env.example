# ===========================================
# GetWhiteIP — Y☁C IP Hunter
# ===========================================
# Скопируйте в .env и заполните значения.
# cp .env.example .env
#
# ⚠️ Не коммитьте .env — он в .gitignore

# -------------------------------------------
# Авторизация (один из вариантов обязательно)
# -------------------------------------------
# 1. IAM токен: yc iam create-token
YC_IAM_TOKEN=

# 2. Путь к JSON-ключу сервисного аккаунта (авторизованный ключ)
#    Консоль → IAM → Сервисные аккаунты → Создать авторизованный ключ
YC_SERVICE_ACCOUNT_KEY_FILE=authorized_key.json

# 3. OAuth токен (для личного аккаунта)
# YC_OAUTH_TOKEN=

# -------------------------------------------
# Обязательно
# -------------------------------------------
# ID каталога: yc config list или Консоль → URL
YC_FOLDER_ID=

# -------------------------------------------
# Опционально
# -------------------------------------------
# Префиксы IP для поиска (через запятую)
# По умолчанию: 51.250., 158.160.
IP_PREFIXES=51.250.,158.160.

# Только для 51.250: IP_PREFIXES=51.250.

# -------------------------------------------
# Режим npm run slow (--slow)
# -------------------------------------------
# Зоны через запятую (по умолчанию a,b)
# SLOW_ZONES=ru-central1-a,ru-central1-b

# Сколько адресов за один батч (по умолчанию 5)
# SLOW_BATCH=5

# Пауза между батчами, мс (по умолчанию 60000)
# SLOW_INTERVAL_MS=60000

# Перед циклом: один create+delete для проверки API (по умолчанию true)
# SLOW_PREFLIGHT=true

# DDoS protection в externalIpv4AddressSpec.requirements (по умолчанию выкл)
# ENABLE_DDOS_PROTECTION=false
# DDOS_PROTECTION_PROVIDER=qrator

# -------------------------------------------
# Режим npm run hunt (--hunt)
# -------------------------------------------
# BATCH_SIZE=15
